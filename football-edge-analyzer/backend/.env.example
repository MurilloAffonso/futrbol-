ENVIRONMENT=local
DATABASE_URL=sqlite:///./football_edge.db

FLASHSCORE_BASE_URL=
FLASHSCORE_API_KEY=
FLASHSCORE_CLIENT_ID=
FLASHSCORE_CLIENT_SECRET=
FLASHSCORE_RATE_LIMIT_PER_MINUTE=60
FLASHSCORE_TIMEOUT_SECONDS=15
FLASHSCORE_PROVIDER_ENABLED=false

